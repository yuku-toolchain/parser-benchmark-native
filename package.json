{
	"name": "ecmascript-parser-benchmark-native",
	"type": "module",
	"private": true,
	"scripts": {
		"bench": "bun scripts/load-files.ts && bun run build && bun bench:typescript && bun bench:three && bun bench:react && bun readme",
		"build": "bun build:zig && bun build:rust",
		"build:zig": "cd zig && zig build --release=fast && cp ./zig-out/bin/yuku_typescript ./zig-out/bin/yuku_three ./zig-out/bin/yuku_react ./zig-out/bin/yuku_semantic_typescript ./zig-out/bin/yuku_semantic_three ./zig-out/bin/yuku_semantic_react ../bin",
		"build:rust": "cd rust && cargo build --release && cp ./target/release/oxc_typescript ./target/release/oxc_three ./target/release/oxc_react ./target/release/oxc_semantic_typescript ./target/release/oxc_semantic_three ./target/release/oxc_semantic_react ./target/release/swc_typescript ./target/release/swc_three ./target/release/swc_react ../bin",
		"bench:typescript": "hyperfine --shell=none --warmup 30 --min-runs 200 ./bin/yuku_typescript ./bin/oxc_typescript ./bin/swc_typescript ./bin/yuku_semantic_typescript ./bin/oxc_semantic_typescript --export-json result/typescript.json",
		"bench:three": "hyperfine --shell=none --warmup 30 --min-runs 200 ./bin/yuku_three ./bin/oxc_three ./bin/swc_three ./bin/yuku_semantic_three ./bin/oxc_semantic_three --export-json result/three.json",
		"bench:react": "hyperfine --shell=none --warmup 30 --min-runs 200 ./bin/yuku_react ./bin/oxc_react ./bin/swc_react ./bin/yuku_semantic_react ./bin/oxc_semantic_react --export-json result/react.json",
		"readme": "bun scripts/generate-readme.ts"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/node": "^25.0.10"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"chart.js": "^4.5.1",
		"chartjs-node-canvas": "^5.0.0"
	}
}
